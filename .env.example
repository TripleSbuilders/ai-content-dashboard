# Server (copy to server/.env)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
API_SECRET=change-me-long-random
# PostgreSQL (Supabase Shared pooler, IPv4). User is postgres.<project-ref>, not postgres.
# Use ?pgbouncer=true on port 6543 (transaction pooler). sslmode=require in the URL is stripped
# at runtime so node-pg uses TLS with rejectUnauthorized:false (Supabase certs).
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
PORT=8787
CORS_ORIGIN=http://localhost:5173
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
SUPER_ADMIN_EMAIL=

# Optional Phase 2 email (Resend)
RESEND_API_KEY=
RESEND_FROM=noreply@yourdomain.com
ADMIN_ALERT_EMAIL=
CLIENT_DELAY_EMAIL_ENABLED=false
ADMIN_ALERTS_ENABLED=true

# Phase 3
RATE_LIMIT_PER_MINUTE=60
API_MAX_CONTENT_LENGTH_BYTES=262144
TRUST_X_FORWARDED_FOR=true
ANALYTICS_INGEST_RATE_LIMIT=30
ANALYTICS_INGEST_RATE_WINDOW_MS=60000
ANALYTICS_MAX_CONTENT_LENGTH_BYTES=5120
DEMO_MODE=false
APP_EDITION=self_serve
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_AUTH_SECRET=
# When true, requests with include_content_package in the kit body run a chained Gemini pipeline (main kit + ideas + parallel hooks/templates) and merge content_ideas_package into result_json.
CONTENT_PACKAGE_CHAIN_ENABLED=false
TELEGRAM_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=
ADMIN_BASE_URL=

# Client (copy to client/.env.local)
VITE_API_URL=http://localhost:8787
VITE_AUTH_REDIRECT_URL=
VITE_V2_CANONICAL_URL=https://ai-content-dashboard-app-v2.onrender.com/wizard/social
# Enables V1 public redirect gate. Keep false for local development unless testing cutover.
VITE_V1_PUBLIC_DECOMMISSION=false
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_WHATSAPP_SALES_NUMBER=201025364905
# Set true to show demo banner and match server DEMO_MODE for local UX
VITE_DEMO_MODE=false
VITE_APP_EDITION=self_serve
